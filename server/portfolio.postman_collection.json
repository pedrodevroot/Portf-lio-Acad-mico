          }
        }
      ]
    },
    {
      "name": "Formações",
      "item": [
        {
          "name": "GET - Listar todas",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/formacoes", "host": ["{{baseUrl}}"], "path": ["api", "formacoes"] }
          }
        },
        {
