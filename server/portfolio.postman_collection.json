          }
        },
        {
          "name": "DELETE - Remover formação",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/formacoes/1", "host": ["{{baseUrl}}"], "path": ["api", "formacoes", "1"] }
          }
        }
      ]
    }
  ]
}
