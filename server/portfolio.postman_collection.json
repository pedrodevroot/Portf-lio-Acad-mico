{
  "info": {
    "name": "Portfólio Acadêmico - API",
    "description": "Coleção para testar a API do portfólio (projetos, cursos, formações).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" }
  ],
  "item": [
    {
      "name": "Projetos",
      "item": [
        {
          "name": "GET - Listar todos",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/projetos", "host": ["{{baseUrl}}"], "path": ["api", "projetos"] }
          }
        },
        {
          "name": "GET - Buscar por ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/projetos/1", "host": ["{{baseUrl}}"], "path": ["api", "projetos", "1"] }
          }
        },
        {
          "name": "POST - Criar projeto",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Novo Projeto\",\n  \"link\": \"https://github.com/pedrodevroot/novo-projeto\",\n  \"imagem\": \"assets/img/novo.png\",\n  \"descricao\": \"Descrição do novo projeto\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/projetos", "host": ["{{baseUrl}}"], "path": ["api", "projetos"] }
          }
        },
        {
          "name": "PUT - Atualizar projeto",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Projeto Atualizado\",\n  \"descricao\": \"Descrição atualizada\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/projetos/1", "host": ["{{baseUrl}}"], "path": ["api", "projetos", "1"] }
          }
        },
        {
          "name": "DELETE - Remover projeto",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/projetos/1", "host": ["{{baseUrl}}"], "path": ["api", "projetos", "1"] }
          }
        }
      ]
    },
    {
      "name": "Cursos",
      "item": [
        {
          "name": "GET - Listar todos",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/cursos", "host": ["{{baseUrl}}"], "path": ["api", "cursos"] }
